<% content_for :title, "Ranking - Bet do Dia" %>

<div class="mb-6">
  <h1 class="text-2xl font-black text-gray-900">Ranking de Apostadores 🏆</h1>
  <p class="text-gray-500 text-sm mt-1">Pontuação ponderada pela confiança do palpite: Baixa = 1pt · Média = 2pts · Alta = 3pts</p>
</div>

<% ranked = @top_users.to_a %>
<% if ranked.empty? %>
  <div class="text-center py-16 text-gray-400">
    <div class="text-5xl mb-4">🏅</div>
    <p class="text-lg font-medium">Nenhum palpite avaliado ainda.</p>
    <p class="text-sm mt-2">Assim que jogos forem encerrados o ranking será atualizado.</p>
  </div>
<% else %>

  <%# Pódio top 3 %>
  <% if ranked.size >= 1 %>
    <div class="flex items-end justify-center gap-3 mb-8">

      <%# 2º lugar %>
      <% if ranked[1] %>
        <div class="flex flex-col items-center">
          <div class="w-16 h-16 rounded-full bg-gray-200 flex items-center justify-center text-2xl font-black text-gray-500 mb-2">
            <%= ranked[1].username[0].upcase %>
          </div>
          <p class="text-xs font-bold text-gray-700 mb-1"><%= ranked[1].display_name %></p>
          <p class="text-xs text-gray-500 mb-2"><%= ranked[1].ranking_score %> pts</p>
          <div class="w-24 bg-gray-300 rounded-t-xl flex flex-col items-center justify-end py-3" style="height:80px">
            <span class="text-2xl">🥈</span>
          </div>
        </div>
      <% end %>

      <%# 1º lugar %>
      <div class="flex flex-col items-center">
        <div class="text-3xl mb-1">👑</div>
        <div class="w-20 h-20 rounded-full bg-yellow-400 flex items-center justify-center text-3xl font-black text-yellow-900 mb-2">
          <%= ranked[0].username[0].upcase %>
        </div>
        <p class="text-sm font-black text-white mb-1"><%= ranked[0].display_name %></p>
        <p class="text-xs text-yellow-700 font-bold mb-2"><%= ranked[0].ranking_score %> pts</p>
        <div class="w-28 bg-yellow-400 rounded-t-xl flex flex-col items-center justify-end py-3" style="height:110px">
          <span class="text-3xl">🥇</span>
        </div>
      </div>

      <%# 3º lugar %>
      <% if ranked[2] %>
        <div class="flex flex-col items-center">
          <div class="w-16 h-16 rounded-full bg-orange-100 flex items-center justify-center text-2xl font-black text-orange-700 mb-2">
            <%= ranked[2].username[0].upcase %>
          </div>
          <p class="text-xs font-bold text-gray-700 mb-1"><%= ranked[2].display_name %></p>
          <p class="text-xs text-gray-500 mb-2"><%= ranked[2].ranking_score %> pts</p>
          <div class="w-24 bg-orange-300 rounded-t-xl flex flex-col items-center justify-end py-3" style="height:60px">
            <span class="text-2xl">🥉</span>
          </div>
        </div>
      <% end %>

    </div>
  <% end %>

  <%# Tabela completa %>
  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 text-left text-gray-500 border-b border-gray-100">
          <th class="px-4 py-3 font-semibold w-10">#</th>
          <th class="px-4 py-3 font-semibold">Apostador</th>
          <th class="px-4 py-3 font-semibold text-center">Pontos</th>
          <th class="px-4 py-3 font-semibold text-center">Acertos</th>
          <th class="px-4 py-3 font-semibold text-center hidden sm:table-cell">Palpites</th>
          <th class="px-4 py-3 font-semibold text-center hidden sm:table-cell">Taxa</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50">
        <% ranked.each_with_index do |user, idx| %>
          <tr class="hover:bg-gray-50 <%= idx < 3 ? 'font-medium' : '' %>">
            <td class="px-4 py-3 text-center">
              <% if idx == 0 %>
                <span class="text-lg">🥇</span>
              <% elsif idx == 1 %>
                <span class="text-lg">🥈</span>
              <% elsif idx == 2 %>
                <span class="text-lg">🥉</span>
              <% else %>
                <span class="text-gray-400 font-semibold"><%= idx + 1 %></span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-sm font-black text-green-700 shrink-0">
                  <%= user.username[0].upcase %>
                </div>
                <span class="text-gray-900"><%= user.display_name %></span>
              </div>
            </td>
            <td class="px-4 py-3 text-center">
              <span class="font-black text-green-700"><%= user.ranking_score %></span>
            </td>
            <td class="px-4 py-3 text-center text-gray-700"><%= user.correct_tips_count %></td>
            <td class="px-4 py-3 text-center text-gray-500 hidden sm:table-cell"><%= user.judged_tips_count %></td>
            <td class="px-4 py-3 text-center hidden sm:table-cell">
              <% rate = user.accuracy_rate %>
              <span class="text-xs font-semibold px-2 py-0.5 rounded-full <%= rate >= 60 ? 'bg-green-100 text-green-700' : rate >= 40 ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-600' %>">
                <%= rate %>%
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
