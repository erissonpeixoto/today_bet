<% content_for :title, "#{@match.title} - Bet do Dia" %>

<%# Match header card %>
<div class="bg-[#1a2535] border border-[#243040] mb-1">
  <%# League + status bar %>
  <div class="flex items-center justify-between px-5 py-2.5 bg-[#152030] border-b border-[#243040]">
    <span class="text-xs font-black text-[#00c853] uppercase tracking-widest">
      ⚽ <%= @match.league %>
    </span>
    <% if @match.live? %>
      <span class="flex items-center gap-1.5 text-xs font-black text-red-400 uppercase">
        <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse inline-block"></span>
        Ao Vivo
      </span>
    <% elsif @match.finished? %>
      <span class="text-xs text-gray-500 uppercase font-bold tracking-wide">Encerrado</span>
    <% else %>
      <span class="text-xs text-gray-400 font-mono"><%= @match.formatted_date %></span>
    <% end %>
  </div>

  <%# Teams display %>
  <div class="flex items-center justify-center gap-6 px-6 py-8">
    <div class="text-center flex-1">
      <% if @match.home_club&.logo_url.present? %>
        <img src="<%= @match.home_club.logo_url %>" alt="<%= @match.home_team %>" class="w-16 h-16 object-contain mx-auto mb-3" onerror="this.style.display='none'">
      <% end %>
      <p class="text-xl font-black text-white leading-tight"><%= @match.home_team %></p>
      <p class="text-[11px] text-gray-500 mt-1.5 uppercase tracking-widest">Mandante</p>
    </div>
    <div class="text-center px-4">
      <span class="text-2xl font-black text-gray-500">VS</span>
    </div>
    <div class="text-center flex-1">
      <% if @match.away_club&.logo_url.present? %>
        <img src="<%= @match.away_club.logo_url %>" alt="<%= @match.away_team %>" class="w-16 h-16 object-contain mx-auto mb-3" onerror="this.style.display='none'">
      <% end %>
      <p class="text-xl font-black text-white leading-tight"><%= @match.away_team %></p>
      <p class="text-[11px] text-gray-500 mt-1.5 uppercase tracking-widest">Visitante</p>
    </div>
  </div>

  <div class="border-t border-[#243040] px-5 py-2.5 text-center">
    <span class="text-xs text-gray-500"><%= @tips.count %> palpite<%= @tips.count == 1 ? "" : "s" %> publicados</span>
  </div>
</div>

<%# Post tip form %>
<% if user_signed_in? %>
  <div class="bg-[#1a2535] border border-[#243040] p-5 mb-1">
    <h2 class="text-sm font-black text-white uppercase tracking-wide mb-4 flex items-center gap-2">
      <span class="text-[#00c853]">🔥</span> Publique seu Palpite
    </h2>

    <%= form_with model: [@match, @tip], class: "space-y-4" do |f| %>
      <% if @tip.errors.any? %>
        <div class="bg-[#2a0d0d] border border-[#5c1a1a] rounded p-3 text-xs text-red-400">
          <% @tip.errors.full_messages.each do |msg| %>
            <p>• <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="grid sm:grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">Mercado</label>
          <%= f.select :market,
            Tip::MARKET_LABELS.map { |k, v| [v, k] },
            { include_blank: "Escolha o mercado..." },
            class: "w-full bg-[#0f1923] border border-[#2d3f50] text-white rounded px-3 py-2.5 text-sm focus:outline-none focus:border-[#00c853] focus:ring-1 focus:ring-[#00c853] transition-colors" %>
        </div>

        <div>
          <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">Confiança</label>
          <%= f.select :confidence,
            [["🟡 Baixa", "baixa"], ["🟠 Média", "media"], ["🔴 Alta", "alta"]],
            { include_blank: "Selecione..." },
            class: "w-full bg-[#0f1923] border border-[#2d3f50] text-white rounded px-3 py-2.5 text-sm focus:outline-none focus:border-[#00c853] focus:ring-1 focus:ring-[#00c853] transition-colors" %>
        </div>
      </div>

      <div>
        <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">
          Justificativa <span class="text-gray-500 font-normal normal-case">(mín. 20 caracteres)</span>
        </label>
        <%= f.text_area :justification,
          rows: 3,
          placeholder: "Ex: Time mandante em casa há 6 jogos sem perder, defesa do visitante com 3 desfalques...",
          class: "w-full bg-[#0f1923] border border-[#2d3f50] text-white rounded px-3 py-2.5 text-sm focus:outline-none focus:border-[#00c853] focus:ring-1 focus:ring-[#00c853] transition-colors resize-none placeholder-gray-700" %>
      </div>

      <%= f.submit "🔥 Publicar Palpite",
        class: "w-full bg-[#00c853] hover:bg-[#00b84a] text-black font-black py-3 rounded text-sm uppercase tracking-wider transition-colors cursor-pointer" %>
    <% end %>
  </div>
<% else %>
  <div class="bg-[#1a2535] border border-[#243040] p-6 mb-1 text-center">
    <p class="text-gray-300 font-bold text-sm mb-1">Faça login para publicar seu palpite!</p>
    <p class="text-gray-500 text-xs mb-4">Junte-se à comunidade e compartilhe sua análise</p>
    <div class="flex justify-center gap-2">
      <%= link_to "Entrar", new_user_session_path, class: "border border-[#243040] text-gray-300 font-black px-6 py-2.5 text-xs uppercase tracking-wide hover:text-white hover:border-[#3d4f60] transition-colors" %>
      <%= link_to "Criar Conta", new_user_registration_path, class: "bg-[#00c853] text-black font-black px-6 py-2.5 text-xs uppercase tracking-wide hover:bg-[#00b84a] transition-colors" %>
    </div>
  </div>
<% end %>

<%# Tips list %>
<div class="mt-4">
  <div class="flex items-center gap-3 mb-3">
    <h2 class="text-sm font-black text-white uppercase tracking-wide">Palpites</h2>
    <span class="text-[11px] text-gray-500">ordenados por 🔥 mais quentes</span>
  </div>

  <% if @tips.empty? %>
    <div class="text-center py-14 text-gray-700 bg-[#1a2535] border border-[#243040]">
      <div class="text-4xl mb-3">💬</div>
      <p class="text-sm">Seja o primeiro a postar um palpite!</p>
    </div>
  <% else %>
    <div class="space-y-0.5">
      <% @tips.each_with_index do |tip, index| %>
        <%= render "tips/tip", tip: tip, rank: index + 1 %>
      <% end %>
    </div>
  <% end %>
</div>
