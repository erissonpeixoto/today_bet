<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-xl font-bold text-slate-900">Clubes</h1>
    <p class="text-sm text-slate-400 mt-0.5">Gerencie os times cadastrados</p>
  </div>
  <%= link_to new_admin_football_club_path, class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm" do %>
    <span class="text-base leading-none">+</span> Novo Clube
  <% end %>
</div>

<div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-slate-50 border-b border-slate-200 text-left">
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Logo</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Nome</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">URL do Logo</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @clubs.each do |club| %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-6 py-3">
            <% if club.logo_url.present? %>
              <img src="<%= club.logo_url %>" alt="<%= club.name %>" class="w-8 h-8 object-contain" onerror="this.style.display='none'">
            <% else %>
              <span class="text-xl">⚽</span>
            <% end %>
          </td>
          <td class="px-6 py-4 font-semibold text-slate-800"><%= club.name %></td>
          <td class="px-6 py-4 text-slate-400 text-xs truncate max-w-xs">
            <%= club.logo_url.present? ? club.logo_url.truncate(60) : "—" %>
          </td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-3 justify-end">
              <%= link_to "Editar", edit_admin_football_club_path(club),
                class: "text-xs font-semibold text-indigo-600 hover:text-indigo-800 hover:underline transition-colors" %>
              <%= button_to "Excluir", admin_football_club_path(club), method: :delete,
                data: { turbo_confirm: "Excluir este clube? As partidas vinculadas perderão a referência." },
                class: "text-xs font-semibold text-red-400 hover:text-red-600 hover:underline transition-colors cursor-pointer bg-transparent" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
