<%# Page header %>
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-xl font-bold text-slate-900">Jogos</h1>
    <p class="text-sm text-slate-400 mt-0.5">Gerencie as partidas cadastradas</p>
  </div>
  <%= link_to new_admin_match_path, class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm" do %>
    <span class="text-base leading-none">+</span> Novo Jogo
  <% end %>
</div>

<%# Table %>
<div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="bg-slate-50 border-b border-slate-200 text-left">
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Jogo</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Liga</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Data</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider text-center">Palpites</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @matches.each do |match| %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-6 py-4 font-medium text-slate-800"><%= match.title %></td>
          <td class="px-6 py-4 text-slate-500 text-xs"><%= match.league %></td>
          <td class="px-6 py-4 text-slate-500 font-mono text-xs"><%= match.formatted_date %></td>
          <td class="px-6 py-4">
            <% if match.live? %>
              <span class="inline-flex items-center gap-1 text-xs font-semibold bg-red-50 text-red-600 border border-red-100 px-2.5 py-1 rounded-full">
                <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span> Ao Vivo
              </span>
            <% elsif match.finished? %>
              <span class="text-xs font-semibold bg-slate-100 text-slate-500 px-2.5 py-1 rounded-full">Encerrado</span>
            <% else %>
              <span class="text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-100 px-2.5 py-1 rounded-full">Agendado</span>
            <% end %>
          </td>
          <td class="px-6 py-4 text-center">
            <span class="text-xs font-semibold text-slate-600 bg-slate-100 px-2.5 py-1 rounded-full"><%= match.tips.count %></span>
          </td>
          <td class="px-6 py-4">
            <div class="flex items-center gap-3 justify-end">
              <%= link_to "Resultados", admin_match_tips_path(match),
                class: "text-xs font-semibold text-emerald-600 hover:text-emerald-800 hover:underline transition-colors" %>
              <%= link_to "Editar", edit_admin_match_path(match),
                class: "text-xs font-semibold text-indigo-600 hover:text-indigo-800 hover:underline transition-colors" %>
              <%= button_to "Excluir", admin_match_path(match), method: :delete,
                data: { turbo_confirm: "Excluir esse jogo e todos os palpites?" },
                class: "text-xs font-semibold text-red-400 hover:text-red-600 hover:underline transition-colors cursor-pointer bg-transparent" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @pagy.pages > 1 %>
  <div class="mt-5 flex items-center justify-between text-sm">
    <span class="text-slate-400 text-xs">Página <%= @pagy.page %> de <%= @pagy.pages %></span>
    <div class="flex gap-1">
      <% if @pagy.prev %>
        <%= link_to "← Anterior", admin_matches_path(page: @pagy.prev),
          class: "px-3 py-1.5 text-xs bg-white border border-slate-200 rounded-lg hover:bg-slate-50 text-slate-600 transition-colors" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Próxima →", admin_matches_path(page: @pagy.next),
          class: "px-3 py-1.5 text-xs bg-white border border-slate-200 rounded-lg hover:bg-slate-50 text-slate-600 transition-colors" %>
      <% end %>
    </div>
  </div>
<% end %>
