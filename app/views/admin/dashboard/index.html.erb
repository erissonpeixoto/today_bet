<%# Page header %>
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="text-xl font-bold text-slate-900">Dashboard</h1>
    <p class="text-sm text-slate-400 mt-0.5">Visão geral da plataforma</p>
  </div>
  <%= link_to new_admin_match_path, class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors shadow-sm" do %>
    <span class="text-base leading-none">+</span> Novo Jogo
  <% end %>
</div>

<%# Stats cards %>
<div class="grid grid-cols-3 gap-5 mb-8">
  <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Jogos</span>
      <span class="text-lg">⚽</span>
    </div>
    <p class="text-3xl font-black text-slate-900"><%= @matches_count %></p>
    <p class="text-xs text-slate-400 mt-1">cadastrados</p>
  </div>

  <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Palpites</span>
      <span class="text-lg">🔥</span>
    </div>
    <p class="text-3xl font-black text-indigo-600"><%= @tips_count %></p>
    <p class="text-xs text-slate-400 mt-1">publicados</p>
  </div>

  <div class="bg-white border border-slate-200 rounded-xl p-5 shadow-sm">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Usuários</span>
      <span class="text-lg">👤</span>
    </div>
    <p class="text-3xl font-black text-slate-900"><%= @users_count %></p>
    <p class="text-xs text-slate-400 mt-1">registrados</p>
  </div>
</div>

<%# Recent matches table %>
<div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
  <div class="flex items-center justify-between px-6 py-4 border-b border-slate-100">
    <h2 class="text-sm font-semibold text-slate-700">Jogos Recentes</h2>
    <%= link_to "Ver todos →", admin_matches_path, class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" %>
  </div>

  <table class="w-full text-sm">
    <thead>
      <tr class="bg-slate-50 border-b border-slate-100 text-left">
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Jogo</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Liga</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Data</th>
        <th class="px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">Status</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-50">
      <% @recent_matches.each do |match| %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="px-6 py-3.5 font-medium text-slate-800"><%= match.title %></td>
          <td class="px-6 py-3.5 text-slate-500"><%= match.league %></td>
          <td class="px-6 py-3.5 text-slate-500 font-mono text-xs"><%= match.formatted_date %></td>
          <td class="px-6 py-3.5">
            <% if match.live? %>
              <span class="inline-flex items-center gap-1 text-xs font-semibold bg-red-50 text-red-600 border border-red-100 px-2.5 py-1 rounded-full">
                <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span> Ao Vivo
              </span>
            <% elsif match.finished? %>
              <span class="text-xs font-semibold bg-slate-100 text-slate-500 px-2.5 py-1 rounded-full">Encerrado</span>
            <% else %>
              <span class="text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-100 px-2.5 py-1 rounded-full">Agendado</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
