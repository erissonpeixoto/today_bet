<div class="mt-5 flex flex-col gap-2 text-center">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Já tenho conta — Entrar", new_session_path(resource_name), class: "text-xs text-gray-400 hover:text-[#00c853] transition-colors" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Criar conta gratuita", new_registration_path(resource_name), class: "text-xs text-gray-400 hover:text-[#00c853] transition-colors" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Esqueci minha senha", new_password_path(resource_name), class: "text-xs text-gray-500 hover:text-gray-300 transition-colors" %>
  <% end %>
</div>
